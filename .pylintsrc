[MASTER]
# Specify a black list of names that should not be used.
bad-names=
    foo,
    bar,
    baz,
    wtf,
    fuck

# A comma-separated list of package or module names from which to load Pylint
# plugins (plugins are loaded after .pylintrc and pythonpath are set).
load-plugins=

# Add files or directories to the blacklist. They should be base names, not
# paths.
ignore=tests,uv.lock,*.txt

[MESSAGES CONTROL]
# Disable the message, report, category or checker with the given id(s). You
# can either specify multiple ids separated by commas (no space in between)
# or repeat this option multiple times.
# See https://pylint.readthedocs.io/en/latest/user_guide/messages/messages_by_category.html
disable=
    C0114, # Missing module docstring
    C0115, # Missing class docstring
    C0116, # Missing function or method docstring
    R0903, # Too few public methods
    W0511  # TODO/FIXME comments

[REPORTS]
# Python expression which should return a score less than or equal to the
# specified score to be considered a failure.
min-score=7.0

[FORMAT]
# Maximum number of characters on a line (default: 100).
max-line-length=100

[TYPECHECK]
# List of members which are set dynamically and missed by pylint inference
# system, and so shouldn't raise no-member messages.
generated-members=
    SQLAlchemy.query,
    db.session

[DESIGN]
# Maximum number of arguments for function or method (default: 5).
max-args=7

# Maximum number of locals for function or method (default: 15).
max-locals=15

# Maximum number of statements in function or method (default: 50).
max-statements=50

# Maximum number of public methods for a class (default: 7).
max-public-methods=10
